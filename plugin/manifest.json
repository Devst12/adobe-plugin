{
  "id": "com.adobe.uxp.caption-automate",
  "name": "AutoCaption Pro",
  "version": "1.0.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.5"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "caption-automate",
      "label": {
        "default": "AutoCaption Pro"
      },
      "minimumSize": {
        "width": 400,
        "height": 500
      },
      "maximumSize": {
        "width": 1200,
        "height": 1000
      },
      "preferredDockedSize": {
        "width": 450,
        "height": 600
      },
      "preferredFloatingSize": {
        "width": 450,
        "height": 600
      },
      "icons": [
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_D.png",
          "scale": [1, 2],
          "theme": ["dark", "darkest"],
          "species": ["generic"]
        },
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_N.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"],
          "species": ["generic"]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 32,
      "height": 32,
      "path": "icons/icon_D.png",
      "scale": [1, 2],
      "theme": ["dark", "darkest"],
      "species": ["generic"]
    },
    {
      "width": 32,
      "height": 32,
      "path": "icons/icon_N.png",
      "scale": [1, 2],
      "theme": ["lightest", "light"],
      "species": ["generic"]
    }
  ]
}